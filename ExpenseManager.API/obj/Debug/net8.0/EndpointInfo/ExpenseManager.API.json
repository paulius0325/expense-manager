{
  "openapi": "3.0.1",
  "info": {
    "title": "ExpenseManager.API",
    "version": "1.0"
  },
  "paths": {
    "/api/expense": {
      "post": {
        "tags": [
          "Expense"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateExpenseDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateExpenseDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateExpenseDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "tags": [
          "Expense"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/expense/{id}": {
      "delete": {
        "tags": [
          "Expense"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateExpenseDto": {
        "required": [
          "category",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "amount": {
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          },
          "category": {
            "$ref": "#/components/schemas/ExpenseCategory"
          }
        },
        "additionalProperties": false
      },
      "ExpenseCategory": {
        "enum": [
          "Food",
          "Travel",
          "Utilities",
          "Entertainment",
          "Other"
        ],
        "type": "string"
      }
    }
  }
}